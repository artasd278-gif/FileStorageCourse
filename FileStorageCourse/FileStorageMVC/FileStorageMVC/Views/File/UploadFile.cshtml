@{
    ViewBag.Title = "Загрузка файла";
    bool isSuccess = ViewBag.IsSuccess == true;
    int uploadedRaw;
    int? uploadedId = int.TryParse(Convert.ToString(ViewBag.UploadedFileId), out uploadedRaw) ? uploadedRaw : (int?)null;
    string maxSizeText = Convert.ToString(ViewBag.MaxFileSizeText) ?? "10 МБ";
}

<div class="row justify-content-center">
    <div class="col-lg-9 col-xl-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 mb-4">
                    <div>
                        <h1 class="h4 mb-2">Загрузка файла</h1>
                        <p class="text-muted mb-0">Выберите файл и отправьте его в хранилище.</p>
                    </div>
                    <div class="upload-rules p-3 rounded-3">
                        <div class="small fw-semibold mb-1">Ограничения</div>
                        <ul class="small text-muted mb-0 ps-3">
                            <li>Максимальный размер: @maxSizeText</li>
                            <li>Допустимые форматы: любые</li>
                        </ul>
                    </div>
                </div>

                @using (Html.BeginForm("UploadFile", "File", FormMethod.Post, new { enctype = "multipart/form-data" }))
                {
                    <div class="mb-3">
                        <label for="fileInput" class="form-label">Выберите файл</label>
                        <input id="fileInput" type="file" name="file" class="form-control" />
                    </div>
                    <button type="submit" class="btn btn-primary">Загрузить</button>
                }

                @if (ViewBag.Message != null)
                {
                    <div class="alert @(isSuccess ? "alert-success" : "alert-danger") mt-4 mb-0" role="alert">
                        <div>@ViewBag.Message</div>
                        @if (isSuccess && uploadedId.HasValue)
                        {
                            <div class="mt-3 d-flex flex-wrap align-items-center gap-2">
                                <span class="badge text-bg-light">ID файла: @uploadedId.Value</span>
                                <a class="btn btn-sm btn-outline-success" href="@Url.Action("DownloadFile", "File", new { id = uploadedId.Value })">
                                    Скачать этот файл
                                </a>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
