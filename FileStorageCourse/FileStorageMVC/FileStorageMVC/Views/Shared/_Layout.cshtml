@{
    string currentController = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "";
    string currentAction = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "";
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - FileStorage MVC</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body class="app-body">
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm fixed-top app-navbar">
        <div class="container">
            @Html.ActionLink("FileStorage MVC", "Index", "Home", null, new { @class = "navbar-brand fw-bold" })
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="Переключить навигацию">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <li class="nav-item">
                        @Html.ActionLink("Главная", "Index", "Home", null, new { @class = "nav-link " + (currentController == "Home" && currentAction == "Index" ? "active" : "") })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Загрузить файл", "UploadFile", "File", null, new { @class = "nav-link " + (currentController == "File" && currentAction == "UploadFile" ? "active" : "") })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Список файлов", "List", "File", null, new { @class = "nav-link " + (currentController == "File" && currentAction == "List" ? "active" : "") })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("О проекте", "About", "Home", null, new { @class = "nav-link " + (currentController == "Home" && currentAction == "About" ? "active" : "") })
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container body-content">
        @RenderBody()
    </main>

    <footer class="app-footer mt-5">
        <div class="container py-4 d-flex flex-column flex-md-row justify-content-between gap-2">
            <div class="text-muted small">&copy; @DateTime.Now.Year FileStorage MVC</div>
            <div class="text-muted small">Учебный проект: загрузка, хранение и скачивание файлов</div>
        </div>
    </footer>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    <script src="@Url.Content("~/Scripts/app.js")"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
